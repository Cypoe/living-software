# Living Software — minimal required env vars
# Copy to .env and fill in. Never commit .env.

# GitHub repo to track
LS_REPO_OWNER=Cypoe
LS_REPO_NAME=living-software
LS_BRANCH=main

# GitHub PAT: needs repo read + issues write
LS_GH_TOKEN=ghp_xxx

# Shared secret between GitHub Actions notify workflow and this instance
LS_UPDATE_TOKEN=change_me_random_string

# Absolute path to the living-software root on this host
LS_ROOT=/var/www/living-software

# How to pull updates: git | ftp | sftp
LS_DEPLOY_METHOD=git

# --- git pull (simplest if host has git + SSH key to GitHub) ---
LS_GIT_REMOTE=git@github.com:Cypoe/living-software.git

# --- FTP fallback ---
# LS_FTP_HOST=ftp.yourdomain.com
# LS_FTP_USER=ftpuser
# LS_FTP_PASS=ftppass
# LS_FTP_REMOTE_DIR=/public_html/living-software

# --- SFTP fallback ---
# LS_SFTP_HOST=yourdomain.com
# LS_SFTP_PORT=22
# LS_SFTP_USER=sshuser
# LS_SFTP_KEY_PATH=/home/user/.ssh/id_rsa
# LS_SFTP_REMOTE_DIR=/var/www/living-software
